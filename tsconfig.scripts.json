{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "rootDir": "scripts",
    "outDir": "./dist-scripts",
    "target": "ES2020",
    "module": "ESNext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["scripts/**/*.ts"]
}
